# 1.2 All environment variables (Mandate v4)
SUPABASE_URL=https://smawxojcohoqeqyksuvp.supabase.co
SUPABASE_DB_HOST=db.smawxojcohoqeqyksuvp.supabase.co:5432
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://smawxojcohoqeqyksuvp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# Infrastructure
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-secure-redis-password
RABBITMQ_USER=rabbitmq_user
RABBITMQ_PASSWORD=your-secure-rabbitmq-password
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret_password
MINIO_BUCKET_EXPORTS=bs-exports
MINIO_BUCKET_SCRAPER=bs-scraper

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password

# Notifications
RESEND_API_KEY=your-resend-api-key

# OAuth (using GH_ prefix as requested)
GH_CLIENT_ID=your-github-client-id
GH_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Vercel
VERCEL_DEPLOY_HOOK=your-vercel-hook-url

# App settings
ENVIRONMENT=production
PLAYWRIGHT_HEADLESS=true
