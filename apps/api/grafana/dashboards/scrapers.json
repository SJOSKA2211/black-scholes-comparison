{
  "annotations": { "list": [] },
  "editable": true,
  "id": null,
  "panels": [
    {
      "title": "Last SPY Rows Inserted",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "black_scholes_scrape_rows_inserted{market=\"spy\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "amber", "value": 10 }, { "color": "green", "value": 50 }] } }
      }
    },
    {
      "title": "Last NSE Rows Inserted",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "black_scholes_scrape_rows_inserted{market=\"nse\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 5 }] } }
      }
    },
    {
      "title": "Scraper Success Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(black_scholes_scrape_runs_total{status=\"success\"}[7d]) / rate(black_scholes_scrape_runs_total[7d]) * 100", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Scrape Duration History",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "targets": [{ "expr": "black_scholes_scrape_duration_seconds", "refId": "A", "legendFormat": "{{market}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Scraper Errors per Hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [{ "expr": "rate(black_scholes_scrape_errors_total[1h])", "refId": "A", "legendFormat": "{{market}} {{error_type}}" }]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "title": "Scrapers",
  "uid": "black-scholes-scrapers",
  "time": { "from": "now-7d", "to": "now" }
}
