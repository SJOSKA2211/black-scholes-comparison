{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(http_requests_total{job=\"black-scholes-api\"}[5m])", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "amber", "value": 100 }, { "color": "red", "value": 500 }] } } }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(http_requests_total{job=\"black-scholes-api\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"black-scholes-api\"}[5m]) * 100", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "title": "p50 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"black-scholes-api\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "p99 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"black-scholes-api\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 2 }] } } }
    },
    {
      "title": "Requests by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(http_requests_total[5m]) by (handler)", "legendFormat": "{{handler}}", "refId": "A" }]
    },
    {
      "title": "Supabase Query Duration p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(black_scholes_supabase_query_duration_seconds_bucket[5m])) by (table, operation)", "legendFormat": "{{table}} {{operation}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "refresh": "30s",
