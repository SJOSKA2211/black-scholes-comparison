{
  "annotations": { "list": [] },
  "editable": true,
  "id": null,
  "panels": [
    {
      "title": "Computations per Method",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(black_scholes_price_computations_total) by (method_type)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Method MAPE (Relative Accuracy %)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "black_scholes_price_mape_percent", "refId": "A", "legendFormat": "{{method_type}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "amber", "value": 0.1 }, { "color": "red", "value": 0.5 }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "title": "Experiment Grid Progress",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "black_scholes_experiment_grid_progress_ratio * 100", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      }
    },
    {
      "title": "95th Percentile Latency by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(black_scholes_price_computation_duration_seconds_bucket[5m])) by (method_type)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } } }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "title": "Pricing Methods",
  "uid": "black-scholes-methods",
  "time": { "from": "now-6h", "to": "now" }
}
