{
  "annotations": { "list": [] },
  "editable": true,
  "id": null,
  "panels": [
    {
      "title": "Total Experiments",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(black_scholes_experiments_run_total)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "title": "Total Market Data Rows",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(black_scholes_scrape_rows_inserted)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "title": "API Liveness (up)",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "up{job=\"black-scholes-api\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } } }
    },
    {
      "title": "Experiments per Hour",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "targets": [{ "expr": "rate(black_scholes_experiments_run_total[1h]) * 3600", "refId": "A", "legendFormat": "{{method_type}}" }],
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "title": "Research Overview",
  "uid": "black-scholes-overview",
  "time": { "from": "now-24h", "to": "now" }
}
